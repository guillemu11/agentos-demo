# ─── AgentOS Configuration ───────────────────────────────────────────────────

# Workspace
WORKSPACE_NAME=Emirates Marketing Intelligence
WORKSPACE_ROOT=.

# AI — Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# AI — Google Gemini (optional, for embeddings + voice)
GEMINI_API_KEY=

# AI — Pinecone (optional, for knowledge base)
PINECONE_API_KEY=
PINECONE_INDEX=agentos-kb

# Database
PG_HOST=localhost
PG_PORT=5434
PG_DB=agentos
PG_USER=agentos
PG_PASSWORD=changeme

# Server
DASHBOARD_PORT=3001
VITE_API_URL=http://localhost:3001

# Auth
SESSION_SECRET=change-this-to-a-random-string

# Encryption (optional — defaults to SESSION_SECRET)
ENCRYPTION_KEY=
